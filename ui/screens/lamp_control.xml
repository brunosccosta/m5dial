<!--
    Lamp Control Screen
    
    Interface for controlling smart lamps:
    - On/Off toggle
    - Brightness slider
    - Color selection (future)
-->
<screen>
	<view width="240" height="240" flex_flow="column">
		<style name="screen_bg" />

		<!-- Title -->
		<lv_label text="Living Room Lamp" width="200" align="top_mid" y="20">
			<style name="menu_item_large" />
		</lv_label>

		<!-- On/Off Button -->
		<lv_button width="120" height="120" align="center" y="0">
			<lv_label text="ON" align="center">
				<style name="menu_item_large" />
			</lv_label>
		</lv_button>

		<!-- Status text -->
		<lv_label text="Brightness: 75%" align="bottom_mid" y="-20">
			<style name="menu_item_small" />
		</lv_label>
	</view>
</screen>
