<!--
    Climate Control Screen
    
    Interface for controlling air conditioning/heating:
    - Temperature display
    - Temperature adjustment
    - Mode selection
-->
<screen>
	<view width="240" height="240" flex_flow="column">
		<style name="screen_bg" />
		<lv_label text="Air Conditioner" width="200" align="top_mid" y="20">
			<style name="menu_item_large" />
		</lv_label>

		<!-- Current temperature display -->
		<lv_label text="22°C" align="center" y="-30" style_text_font="lv_font_montserrat_48" />

		<!-- Target temperature -->
		<lv_label text="Target: 24°C" align="center" y="30">
			<style name="menu_item_small" />
		</lv_label>

		<!-- Status -->
		<lv_label text="Mode: Cooling" align="bottom_mid" y="-20">
			<style name="menu_item_small" />
		</lv_label>
	</view>
</screen>
